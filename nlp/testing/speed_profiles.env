# PowerShell:
#   Get-Content nlp/src/testing/speed_profiles.env
#   $env:NLP_GENERATOR_ENABLED="0"
#
# Linux/Workbench:
#   export NLP_GENERATOR_ENABLED=0

# Profile A: fastest useful current-manager baseline.
NLP_GENERATOR_ENABLED=0
NLP_RERANKER_ENABLED=0
NLP_EMBEDDING_ENABLED=0

# Profile B: dense retrieval but no answer/reranker model calls.
# NLP_GENERATOR_ENABLED=0
# NLP_RERANKER_ENABLED=0
# NLP_EMBEDDING_ENABLED=1
# NLP_DENSE_TOP_K=32
# NLP_BM25_TOP_K=48

# Profile C: keep SmolLM3 but greatly reduce prompt/output cost.
# NLP_GENERATOR_DOCS_PER_QUESTION=1
# NLP_GENERATOR_DOC_CHUNK_LIMIT=1
# NLP_GENERATOR_MAX_CONTEXT_CHARS=900
# NLP_GENERATOR_MAX_NEW_TOKENS=16
# NLP_GENERATOR_BATCH_SIZE=16
# NLP_RERANK_TOP_K=4

# Profile D: for testing testing/selective_generator_manager.py.
# NLP_SELECTIVE_GENERATOR_MODE=hard_only
# NLP_SELECTIVE_MAX_GROUPS=1
# NLP_GENERATOR_DOCS_PER_QUESTION=1
# NLP_GENERATOR_DOC_CHUNK_LIMIT=1
# NLP_GENERATOR_MAX_CONTEXT_CHARS=900
# NLP_GENERATOR_MAX_NEW_TOKENS=16

