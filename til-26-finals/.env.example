# Copy to .env and edit as needed.

# ─── test competition server ────────────────────────────────────────────────
COMPETITION_SERVER_PORT=8000

# Config JSON under test_competition_server/configs/ (without .json).
# Edit that file to use your team name and your track (novice / advanced).
CONFIG=config_test

# Your team name. til-stubs will fill every other seat in CONFIG.
TEAM_NAME=team-1

# Path to your stage data directory on the host.
# Expected layout: asr/<track>/, cv/<track>/, nlp/<track>.jsonl,
#                  nlp/documents/, nlp/models/nlp_eval_512/
# Example (GCP instance with gcsfuse mount):
#   HOST_DATA_DIR=/home/jupyter/
HOST_DATA_DIR=/home/jupyter/${TEAM_TRACK}

# Artifact Registry repo (used to tag and pull your model images).
# Example: repo-til-26-ryantest
REPO_NAME=repo-til-26-${TEAM_NAME}

# ─── participant-side (til-finals + model containers) ───────────────────────
# Where til-finals reaches the test competition server.
# With network_mode: host, til-finals is on the host network and accesses
# containers via their exposed ports. host.docker.internal resolves to the
# Docker host gateway on both Linux (add host-gateway) and Windows/Mac.
COMPETITION_SERVER_IP=host.docker.internal

# Where til-finals reaches its own model containers (localhost since host net).
LOCAL_IP=host.docker.internal
